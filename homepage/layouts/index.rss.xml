{{- $pages := where site.RegularPages "Section" "blog" -}}
    {{- $pages = $pages.ByDate.Reverse -}}
    {{- $limit := 20 -}}
    {{- $pages = first $limit $pages -}}

<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
    <channel>
        <title>{{ site.Title }}</title>
        <link>{{ site.BaseURL }}</link>
        <description>{{ with site.Params.description }}{{ . }}{{ else }}Recent blog posts on {{ site.Title }}{{ end }}</description>
        <generator>Hugo</generator>
        <language>{{ site.Language.LanguageCode }}</language>
        <lastBuildDate>{{ now.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
        <atom:link href="{{ (printf "%sindex.xml" site.BaseURL) }}" rel="self" type="application/rss+xml"/>

        {{- range $pages }}
        <item>
            <title>{{ .Title }}</title>
            <link>{{ .Permalink }}</link>
            <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
            <guid>{{ .Permalink }}</guid>
            <description>{{ .Summary | plainify }}</description>
        </item>
        {{- end }}
    </channel>
</rss>